      <EntityType Name="TokenCache">
        <Key><PropertyRef Name="InstallationId"/></Key>
        <Property Name="InstallationId" Type="Edm.String" Nullable="false"/>
        <Property Name="Status" Type="Grug.TokenCache.TokenCacheStatus" Nullable="false"/>

        <Property Name="app_jwt_ttl_is_ten_minutes_per_identity_concepts" Type="Edm.Boolean" DefaultValue="false"/>
        <Property Name="install_token_ttl_is_about_one_hour_per_identity_concepts" Type="Edm.Boolean" DefaultValue="false"/>
