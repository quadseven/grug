<?xml version="1.0" encoding="utf-8"?>
<!-- Spec 0004 TokenCache — CSDL companion. Filename must be `model.csdl.xml`. -->
<edmx:Edmx Version="4.0" xmlns:edmx="http://docs.oasis-open.org/odata/ns/edmx">
