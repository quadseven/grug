        <Parameter Name="attestor" Type="Edm.String" Nullable="false"/>
        <ReturnType Type="Grug.TokenCache.TokenCache"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates"><Collection><String>Empty</String></Collection></Annotation>
      </Action>

      <Action Name="Refresh" IsBound="true">
