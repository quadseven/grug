      </Action>

      <Action Name="AttestWorkerInjection" IsBound="true">
        <Parameter Name="bindingParameter" Type="Grug.CfSharedSecret.CfSharedSecret"/>
        <Parameter Name="attestor" Type="Edm.String" Nullable="false"/>
        <ReturnType Type="Grug.CfSharedSecret.CfSharedSecret"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates"><Collection><String>NotProvisioned</String></Collection></Annotation>
      </Action>

      <Action Name="AttestMiddlewareRegistered" IsBound="true">
        <Parameter Name="bindingParameter" Type="Grug.CfSharedSecret.CfSharedSecret"/>
        <Parameter Name="attestor" Type="Edm.String" Nullable="false"/>
        <ReturnType Type="Grug.CfSharedSecret.CfSharedSecret"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates"><Collection><String>NotProvisioned</String></Collection></Annotation>
      </Action>

      <Action Name="AttestMiddlewareSecretSourcedFromSsm" IsBound="true">
        <Parameter Name="bindingParameter" Type="Grug.CfSharedSecret.CfSharedSecret"/>
        <Parameter Name="attestor" Type="Edm.String" Nullable="false"/>
        <ReturnType Type="Grug.CfSharedSecret.CfSharedSecret"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates"><Collection><String>NotProvisioned</String></Collection></Annotation>
      </Action>

      <Action Name="AttestMiddlewareBehavior" IsBound="true">
        <Parameter Name="bindingParameter" Type="Grug.CfSharedSecret.CfSharedSecret"/>
        <Parameter Name="attestor" Type="Edm.String" Nullable="false"/>
        <ReturnType Type="Grug.CfSharedSecret.CfSharedSecret"/>
