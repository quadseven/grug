# graphify-managed knowledge graph — union-merge driver dedupes nodes
# across branches without manual conflict resolution. Setup once per
# clone via `graphify hook install`; this file wires the merge driver
# attribute so the local config takes effect on git merge.
graphify-out/graph.json    merge=graphify-merge
graphify-out/graph.html    merge=graphify-merge
graphify-out/GRAPH_REPORT.md merge=graphify-merge
