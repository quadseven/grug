__pycache__/
*.pyc
.venv/
.DS_Store

# Pulumi local-only state. Stack configs (Pulumi.<stack>.yaml) ARE
# committed — Pulumi natively encrypts any --secret values via stack
# secrets-provider. Plaintext values are intentional.
infra/pulumi/.pulumi/
infra/pulumi/uv.lock
infra/pulumi/venv/

# Service-level
.pytest_cache/
*.egg-info/
dist/
build/
*.pem
*.private-key

# Docker / build artifacts
docker-bake.hcl.local

# Editor / IDE
.vscode/
.idea/
*.swp

# graphify skill outputs:
# - graph.json + graph.html + GRAPH_REPORT.md ARE tracked (team-shared
#   knowledge map, merge-driver-handled per .gitattributes).
# - manifest.json (mtime-keyed) + cost.json (per-run) stay local.
graphify-out/manifest.json
graphify-out/cost.json
# AST cache (~2MB, mtime-keyed, rebuilds free post-clone via hook).
graphify-out/cache/
# graphify runtime helpers (per-machine paths)
graphify-out/.graphify_*

# Web build outputs (re-installable from package-lock + tsconfig)
web/node_modules/
web/tsconfig.tsbuildinfo
.claude/
logs/model-evals/
